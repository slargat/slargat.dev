{
	"name": "slargat-dev",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-02-23",
	"compatibility_flags": [
		"nodejs_compat",
		"no_handle_cross_request_promise_resolution"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	}
}